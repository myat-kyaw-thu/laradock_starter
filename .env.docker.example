# =============================================================
#  Laravel Docker — Environment Example
#  Copy this file to .env.docker and fill in your values:
#
#    cp .env.docker.example .env.docker
#
#  .env.docker is gitignored — never commit real credentials.
# =============================================================

# ── App ───────────────────────────────────────────────────────
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# ── Database ──────────────────────────────────────────────────
# DB_HOST must match the docker-compose service name (mysql)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=laravel

# ── Redis ─────────────────────────────────────────────────────
# REDIS_HOST must match the docker-compose service name (redis)
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Cache / Queue / Session ───────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ── Mail (Mailpit catches all mail locally) ───────────────────
# MAIL_HOST must match the docker-compose service name (mailpit)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"
